---
import { site } from '../site.config.mjs';
---
<footer class="footer">
  <div class="wrap footer__inner">
    <div>
      <div class="footer__brand">🍴 Cyberforks</div>
      <p class="footer__tag">{site.tagline}</p>
    </div>
    <div class="footer__links">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={site.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.blog} target="_blank" rel="noopener">Blog</a>
      <a href={site.instagram} target="_blank" rel="noopener">Instagram</a>
    </div>
  </div>
  <div class="wrap footer__legal">
    <span>© {new Date().getFullYear()} Cyberforks LLC</span>
    <a href="/contact-me">Get in touch →</a>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); background: var(--bg-raised); margin-top: 2rem; }
  .footer__inner {
    display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: space-between;
    padding-block: 2.5rem 1.5rem;
  }
  .footer__brand { font-weight: 700; font-size: 1.05rem; margin-bottom: 0.4rem; }
  .footer__tag { color: var(--text-mute); max-width: 34ch; margin: 0; font-size: 0.95rem; }
  .footer__links { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer__links a { color: var(--text-dim); }
  .footer__legal {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    padding-block: 1.2rem; border-top: 1px solid var(--border);
    color: var(--text-mute); font-size: 0.85rem; font-family: var(--font-mono);
  }
</style>
