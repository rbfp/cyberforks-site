---
import { nav, site } from '../site.config.mjs';
---
<header class="nav">
  <div class="wrap nav__inner">
    <a href="/" class="nav__brand" aria-label="Cyberforks home">
      <img class="nav__mark" src="/images/logo-mark.png" alt="Cyberforks" width="32" height="32" />
      <span>Cyberforks</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__toggle" hidden />
    <label for="nav-toggle" class="nav__burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__links">
      {nav.map((item) => (
        item.children ? (
          <div class="nav__group">
            <button class="nav__link nav__group-btn" type="button">{item.label} <span class="nav__caret">▾</span></button>
            <div class="nav__menu">
              {item.children.map((c) => (
                <a href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener' : undefined}>{c.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a class="nav__link" href={item.href}>{item.label}</a>
        )
      ))}
      <a class="nav__cta btn btn--primary" href="/contact-me">Get in touch</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav__inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.55rem; font-weight: 700; font-size: 1.1rem; color: var(--text); }
  .nav__brand:hover { text-decoration: none; }
  .nav__mark { width: 32px; height: 32px; display: block; }

  .nav__links { display: flex; align-items: center; gap: 0.35rem; }
  .nav__link {
    background: none; border: 0; cursor: pointer; font: inherit;
    color: var(--text-dim); padding: 0.5rem 0.75rem; border-radius: 8px;
    display: inline-flex; align-items: center; gap: 0.3rem;
  }
  .nav__link:hover { color: var(--text); background: var(--bg-raised); text-decoration: none; }
  .nav__caret { font-size: 0.65rem; opacity: 0.7; }

  .nav__group { position: relative; }
  .nav__menu {
    position: absolute; top: calc(100% + 6px); left: 0;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 0.4rem; min-width: 250px;
    display: none; flex-direction: column;
    box-shadow: 0 12px 40px rgba(0,0,0,0.45);
  }
  .nav__group:hover .nav__menu, .nav__group:focus-within .nav__menu { display: flex; }
  .nav__menu a { color: var(--text-dim); padding: 0.55rem 0.7rem; border-radius: 8px; font-size: 0.95rem; }
  .nav__menu a:hover { color: var(--text); background: var(--bg-raised); text-decoration: none; }

  .nav__cta { margin-left: 0.5rem; padding: 0.5rem 1.1rem; font-size: 0.9rem; }

  .nav__burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 8px; }
  .nav__burger span { width: 24px; height: 2px; background: var(--text); border-radius: 2px; transition: 0.2s; }

  @media (max-width: 860px) {
    .nav__burger { display: flex; }
    .nav__links {
      position: absolute; top: 64px; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 0;
      background: var(--bg-raised); border-bottom: 1px solid var(--border);
      padding: 0.6rem var(--gutter) 1.2rem;
      max-height: 0; overflow: hidden; transition: max-height 0.25s ease; visibility: hidden;
    }
    .nav__toggle:checked ~ .nav__links { max-height: 90vh; visibility: visible; }
    .nav__link, .nav__menu a { width: 100%; }
    .nav__group { width: 100%; }
    .nav__menu { position: static; display: flex; border: 0; box-shadow: none; padding-left: 1rem; min-width: 0; background: none; }
    .nav__cta { margin: 0.6rem 0 0; text-align: center; }
  }
</style>
