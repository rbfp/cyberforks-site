---
import Base from '../layouts/Base.astro';

const audits = [
  {
    n: '01',
    title: 'NIST CSF Audits',
    body: 'Evaluating security posture against the NIST Cybersecurity Framework.',
    points: [
      'Stakeholder interviews and controls inventory',
      'Framework function and category mapping',
      'Gap analysis with prioritized remediation roadmap',
      'Executive-ready findings memo',
    ],
    note: 'Where it fits: leadership assessment, board-review prep.',
  },
  {
    n: '02',
    title: 'HIPAA Compliance Audits',
    body: 'Security and Privacy Rule readiness for healthcare orgs and their associates.',
    points: [
      'Risk assessment under §164.308(a)(1)',
      'Business Associate Agreement inventory and review',
      'Technical safeguards evaluation (encryption, access control, audit logging)',
      'Policy and documentation review with remediation planning',
    ],
    note: 'Common triggers: OCR inquiry, incident response, vendor evaluation.',
  },
  {
    n: '03',
    title: 'SOC 2 Type 2 Policy Audits',
    body: 'Pre-audit preparation against the Trust Services Criteria.',
    points: [
      'Policy review and alignment',
      'Gap identification',
      'Policy drafts and revisions',
      'Handoff package for full readiness assessment',
    ],
    note: 'Preparatory work — not the SOC 2 attestation itself.',
  },
  {
    n: '04',
    title: 'Cyber / IT Audits',
    body: 'General security-posture assessment without a specific compliance framework.',
    points: [
      'Asset and access inventory',
      'Patch management and configuration review',
      'Network architecture and segmentation analysis',
      'Documentation, monitoring, and incident-response readiness',
    ],
    note: 'Use cases: inter-audit assessments, baseline establishment.',
  },
];
---
<Base title="Audits" description="Security and compliance audit experience — NIST CSF, HIPAA, SOC 2 policy prep, and general cyber/IT posture.">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Experience</p>
      <h1>Audits</h1>
      <p class="lede">I run hands-on security and compliance audits for teams that want a practitioner's read, not a templated report — prioritized findings you can act on without extra interpretation.</p>
    </div>
  </section>

  <section class="section wrap">
    <div class="grid grid--2">
      {audits.map((a) => (
        <div class="card">
          <span class="card__num">{a.n}</span>
          <h3>{a.title}</h3>
          <p class="muted">{a.body}</p>
          <ul>{a.points.map((p) => <li>{p}</li>)}</ul>
          {a.note && <p class="tag">{a.note}</p>}
        </div>
      ))}
    </div>
  </section>

  <section class="section--tight wrap">
    <div class="card" style="text-align:center;padding:2.5rem 1.5rem;background:var(--bg-raised)">
      <h2 style="margin-bottom:0.6rem">Want to talk shop?</h2>
      <p class="muted" style="max-width:46ch;margin-inline:auto">Always up for a good conversation about security posture and where teams actually stand.</p>
      <a class="btn btn--primary" href="/contact-me" style="margin-top:1rem">Get in touch</a>
    </div>
  </section>
</Base>
