---
import Base from '../layouts/Base.astro';

const services = [
  {
    n: '01',
    title: 'AI Assistant Implementation',
    body: 'Persistent, context-aware assistants with multi-instance architecture, long-term memory, tool integration, and human-oversight controls.',
  },
  {
    n: '02',
    title: 'Agentic DevSecOps',
    body: 'Security-operations AI handling alert triage, incident response, audits, and pipeline integration — with documented reasoning and reversibility.',
  },
  {
    n: '03',
    title: 'AI Security Guardrails',
    body: 'Prompt-injection defense, output validation, tool-call governance, and permission boundaries for agentic systems.',
  },
  {
    n: '04',
    title: 'Vibe Coding Enablement',
    body: 'Helping teams adopt AI coding tools — with code-review practices and collaboration habits that keep quality high.',
  },
];
---
<Base title="Agentic AI" description="Agentic AI experience — security-first assistants, DevSecOps, guardrails, and team enablement.">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Experience</p>
      <h1>Agentic AI</h1>
      <p class="lede">I build AI systems security-first — grounded in real-world experience deploying multi-instance systems, not theoretical frameworks. Here's where I focus.</p>
    </div>
  </section>

  <section class="section wrap">
    <div class="grid grid--2">
      {services.map((s) => (
        <div class="card">
          <span class="card__num">{s.n}</span>
          <h3>{s.title}</h3>
          <p class="muted">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section wrap" style="padding-top:0">
    <p class="eyebrow">On GitHub</p>
    <h2 style="margin-bottom:0.8rem">The projects behind the work</h2>
    <p class="muted" style="max-width:62ch;margin-bottom:1.6rem">The agentic-AI systems I run are public. These are the actual codebases — the persistent, multi-instance assistant framework, and the security layer that keeps it inside its guardrails.</p>
    <div class="grid grid--2">
      <a href="https://github.com/rbfp/Gir-An-Agentic-AI-Assistant" target="_blank" rel="noopener" class="card" style="display:block;color:inherit">
        <h3 style="color:var(--accent)">Agentic AI Assistant (GIR)</h3>
        <p class="muted" style="font-size:0.96rem">The persistent, multi-instance AI assistant framework behind the fleet.</p>
        <span class="muted" style="font-family:var(--font-mono);font-size:0.8rem">View on GitHub →</span>
      </a>
      <a href="https://github.com/rbfp/agentic-ai-assistant-security-guide" target="_blank" rel="noopener" class="card" style="display:block;color:inherit">
        <h3 style="color:var(--accent)">Agentic AI Security Guardrails</h3>
        <p class="muted" style="font-size:0.96rem">The guardrail and hardening layer — action tiers, hooks, and approval gates.</p>
        <span class="muted" style="font-family:var(--font-mono);font-size:0.8rem">View on GitHub →</span>
      </a>
    </div>
  </section>

  <section class="section--tight wrap">
    <div class="card" style="text-align:center;padding:2.5rem 1.5rem;background:var(--bg-raised)">
      <h2 style="margin-bottom:0.6rem">Building something agentic?</h2>
      <p class="muted" style="max-width:46ch;margin-inline:auto">Whether it's a production assistant or guardrails for a system you already run, I'm always glad to compare notes.</p>
      <a class="btn btn--primary" href="/contact-me" style="margin-top:1rem">Get in touch</a>
    </div>
  </section>
</Base>
