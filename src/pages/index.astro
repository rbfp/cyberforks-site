---
import Base from '../layouts/Base.astro';

const services = [
  {
    title: 'Agentic AI',
    href: '/agentic-ai',
    body: 'Building AI systems security-first — persistent assistants, agentic DevSecOps, and guardrails, drawn from real multi-instance deployments, not theory.',
  },
  {
    title: 'Offensive Security',
    href: '/offsec',
    body: 'Adversarial security against real environments — pentest, red team, purple team, and hands-on security engineering. Objective-driven, and I document the full attack chain.',
  },
  {
    title: 'Audits',
    href: '/audits',
    body: "Hands-on security and compliance reads — NIST CSF, HIPAA, SOC 2 prep, and general cyber/IT posture, with prioritized, plain-English findings.",
  },
];
---
<Base title={null} description="Robert Cao — security practitioner. Offensive security, agentic AI, and audits, with the work written up.">
  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Robert Cao · Cyberforks</p>
      <h1>Proving cybersecurity<br />actually works,<br /><span style="color:var(--accent)">one byte at a time.</span></h1>
      <p class="lede">I'm Robert. I work across offensive security, agentic AI, and security auditing — hands-on, building and breaking real systems, and writing up what I learn along the way.</p>
      <div style="display:flex;gap:0.8rem;flex-wrap:wrap;margin-top:2rem">
        <a class="btn btn--primary" href="/experience">See what I work on</a>
        <a class="btn btn--ghost" href="/projects">Read the writeups</a>
      </div>
    </div>
  </section>

  <!-- Who is this -->
  <section class="section wrap">
    <div class="grid grid--2" style="gap:2.5rem;align-items:start">
      <div>
        <p class="eyebrow">Who is this?</p>
        <h2>Cyberforks is me — Robert.</h2>
        <p class="muted">Cyberforks is where I do hands-on, applicable cybersecurity — practical, results-oriented security work, and the home for my projects and writeups.</p>
      </div>
      <div>
        <p class="eyebrow">For the community</p>
        <h2>Playbooks, not paywalls.</h2>
        <p class="muted">When I work something out, I write it down — step-by-step guides and documentation from real work, shared so others can run the same plays.</p>
        <a href="https://blog.cyberforks.com" target="_blank" rel="noopener">Read the blog →</a>
      </div>
    </div>
  </section>

  <!-- Areas -->
  <section class="section wrap" style="padding-top:0">
    <p class="eyebrow">Experience</p>
    <h2 style="margin-bottom:1.6rem">What I work on</h2>
    <div class="grid grid--3">
      {services.map((s) => (
        <a href={s.href} class="card" style="display:block;color:inherit">
          <h3 style="color:var(--accent)">{s.title}</h3>
          <p class="muted" style="font-size:0.96rem">{s.body}</p>
          <span class="muted" style="font-family:var(--font-mono);font-size:0.8rem">Learn more →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="section--tight wrap">
    <div class="card" style="text-align:center;padding:2.5rem 1.5rem;background:var(--bg-raised)">
      <h2 style="margin-bottom:0.6rem">Looking to connect?</h2>
      <p class="muted" style="max-width:48ch;margin-inline:auto">Whether it's a role, a collaboration, or just good security talk — my inbox is open.</p>
      <a class="btn btn--primary" href="/contact-me" style="margin-top:1rem">Get in touch</a>
    </div>
  </section>
</Base>
