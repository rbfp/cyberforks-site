---
import Base from '../layouts/Base.astro';

const services = [
  {
    n: '01',
    title: 'Penetration Testing',
    body: 'Hands-on attack simulation across external, internal, and network layers.',
    points: [
      'External — internet-facing assets',
      'Internal — assumed-breach scenarios',
      'Network — segmentation, lateral movement, Active Directory',
      'Output: findings with reproduction steps and remediation priorities',
    ],
    note: 'Where it fits: compliance milestones, infrastructure changes, annual baseline.',
  },
  {
    n: '02',
    title: 'Red Team',
    body: 'Goal-oriented adversarial simulation — a real test of whether detection and response can stop a determined attacker pursuing a specific objective.',
    points: [
      'Objective-driven scope',
      'Multi-vector approach',
      'Full attack-chain documentation',
      'Joint readout with the blue team',
    ],
  },
  {
    n: '03',
    title: 'Purple Team',
    body: 'Collaborative offense-meets-defense — running attacker TTPs against an environment with the detection team in the room, tuning as we go.',
    points: [
      'Pre-selected TTPs (MITRE ATT&CK aligned)',
      'Live execution with defender visibility',
      'Iterative detection tuning',
      'Detection-gap notes with query and rule recommendations',
    ],
  },
  {
    n: '04',
    title: 'Security Engineering',
    body: 'Hands-on architecture, hardening, and tooling — I build the thing, I don\'t just hand over a deck.',
    points: [
      'Cloud and identity hardening',
      'Detection engineering',
      'Infrastructure-as-code security',
      'Secrets management and zero-trust architecture',
    ],
  },
];
---
<Base title="Offensive Security" description="Offensive security work — pentest, red team, purple team, and security engineering against real environments.">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Experience</p>
      <h1>Offensive Security</h1>
      <p class="lede">I run adversarial security work against real environments — not checkbox exercises against a stripped-down lab. Every effort targets a clear objective, runs under written rules of engagement, and produces findings an engineer or an executive can actually act on.</p>
    </div>
  </section>

  <section class="section wrap">
    <div class="grid grid--2">
      {services.map((s) => (
        <div class="card">
          <span class="card__num">{s.n}</span>
          <h3>{s.title}</h3>
          <p class="muted">{s.body}</p>
          <ul>{s.points.map((p) => <li>{p}</li>)}</ul>
          {s.note && <p class="tag">{s.note}</p>}
        </div>
      ))}
    </div>
  </section>

  <section class="section--tight wrap">
    <div class="card" style="text-align:center;padding:2.5rem 1.5rem;background:var(--bg-raised)">
      <h2 style="margin-bottom:0.6rem">Want to talk shop?</h2>
      <p class="muted" style="max-width:52ch;margin-inline:auto">Happy to get into the weeds on any of this — a role, a collaboration, or just the craft.</p>
      <a class="btn btn--primary" href="/contact-me" style="margin-top:1rem">Get in touch</a>
    </div>
  </section>
</Base>
