{
  // Cloudflare Workers static-assets config.
  // This site is 100% static — no server code. Cloudflare serves the built
  // `dist/` folder as static assets. (Cloudflare now routes new projects
  // through Workers instead of Pages; this is the Workers equivalent of the
  // old Pages "output directory" setting.)
  "name": "cyberforks-site",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist"
  }
}
